<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020509">

    <com.frequenciazero.HouseSceneView
        android:id="@+id/houseScene"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/bottomPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#D9080B10"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingTop="12dp"
        android:paddingRight="18dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/narrativeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:text="Vértice não aparece no mapa desde a evacuação."
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="#F1EDE2" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/frequencyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="RADIO: --.--"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="#88AFC7" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/techLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="3"
            android:text="LOG: casa fria / sem rede"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="#8D969A" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

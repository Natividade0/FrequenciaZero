<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fz_ink">

    <com.frequenciazero.CinematicBackdropView
        android:id="@+id/cinematicBackdrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/phoneShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="12dp"
        android:paddingTop="10dp"
        android:paddingRight="12dp"
        android:paddingBottom="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/topPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#D80A0908"
            app:cardCornerRadius="10dp"
            app:strokeColor="@color/fz_ember_dim"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingTop="12dp"
                android:paddingRight="16dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/screenTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.12"
                        android:text="HELENA"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/fz_text" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/livePill"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_signal_live"
                        android:paddingLeft="10dp"
                        android:paddingTop="4dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="4dp"
                        android:text="03.17"
                        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                        android:textColor="@color/fz_text" />
                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/screenSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="canal seguro / conversa interceptada"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/fz_text_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:id="@+id/contentHost"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/screenMessages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/conversationSignal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="#B8120F0D"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="@color/fz_line"
                    app:strokeWidth="1dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:padding="12dp"
                        android:text="CHAMADA RECUPERADA // ORIGEM PARCIAL // VERTICE"
                        android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                        android:textColor="@color/fz_mineral" />
                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/messageList"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/responseGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp"
                    app:chipSpacingHorizontal="8dp"
                    app:singleLine="false">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/responseConfirm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confirmado."
                        android:textColor="@color/fz_text"
                        app:chipBackgroundColor="@color/fz_panel"
                        app:chipStrokeColor="@color/fz_ember"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/responseFrequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Que frequência?"
                        android:textColor="@color/fz_text"
                        app:chipBackgroundColor="@color/fz_panel"
                        app:chipStrokeColor="@color/fz_line"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/responseMemory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Por que eu esqueceria?"
                        android:textColor="@color/fz_text"
                        app:chipBackgroundColor="@color/fz_panel"
                        app:chipStrokeColor="@color/fz_warning"
                        app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/screenTransmissions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="ARQUIVOS RECEBIDOS"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/fz_ember" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/transmissionList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/screenRestore"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#B8120F0D"
                    app:cardCornerRadius="8dp"
                    app:strokeColor="@color/fz_line"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/restoreFileName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="VX_0317_A.raw"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/fz_text" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/restoreStatus"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="ruído bruto / amostra bloqueada"
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="@color/fz_text_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.frequenciazero.SpectrogramView
                    android:id="@+id/spectrogramView"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="14dp"
                    android:layout_weight="1" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/frequencyReadout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="02.84"
                    android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                    android:textColor="@color/fz_text" />

                <SeekBar
                    android:id="@+id/frequencySlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:max="75"
                    android:progress="14"
                    android:progressBackgroundTint="@color/fz_line"
                    android:progressTint="@color/fz_ember"
                    android:thumbTint="@color/fz_ember" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/captureButton"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:enabled="false"
                    android:text="Capturar Amostra"
                    android:textAllCaps="false"
                    android:textColor="@color/fz_ink"
                    app:backgroundTint="@color/fz_ember"
                    app:cornerRadius="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/screenLog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/logList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/screenMap"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="MAPA PASSIVO"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="@color/fz_ember" />

                    <com.frequenciazero.DeadZoneMapView
                        android:id="@+id/deadZoneMap"
                        android:layout_width="match_parent"
                        android:layout_height="330dp"
                        android:layout_marginTop="12dp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/mapText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:lineSpacingExtra="7dp"
                        android:text="Cidade Vértice\nZona Morta\nAntena\nRádio Âncora"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@color/fz_text" />
                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:id="@+id/screenSettings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/soundSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/settings_row_bg"
                    android:padding="14dp"
                    android:checked="true"
                    android:text="Som"
                    android:textColor="@color/fz_text" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:text="Resetar progresso"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/fz_panel"
                    app:cornerRadius="8dp"
                    app:strokeColor="@color/fz_warning"
                    app:strokeWidth="1dp" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/creditsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/settings_row_bg"
                    android:padding="14dp"
                    android:text="Frequência Zero\nCapítulo 1: Vértice\nUma investigação por sinais, memória e ruído."
                    android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                    android:textColor="@color/fz_text_muted" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/signalDock"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/signal_dock_bg"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="5dp">

            <TextView
                android:id="@+id/navMessages"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="MSG"
                android:textColor="@color/fz_text"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/navTransmissions"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="VX"
                android:textColor="@color/fz_text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/navLog"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="LOG"
                android:textColor="@color/fz_text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/navMap"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="MAP"
                android:textColor="@color/fz_text_muted"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="SYS"
                android:textColor="@color/fz_text_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

<resources>
    <style name="Theme.FrequenciaZero" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:colorAccent">@color/fz_teal</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="colorPrimary">@color/fz_teal</item>
        <item name="colorSecondary">@color/fz_amber</item>
        <item name="colorSurface">@color/fz_panel</item>
        <item name="colorOnSurface">@color/fz_text</item>

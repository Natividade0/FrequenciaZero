<resources>
    <style name="Theme.FrequenciaZero" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:colorAccent">@color/fz_ember</item>
        <item name="colorPrimary">@color/fz_ember</item>
        <item name="colorSecondary">@color/fz_mineral</item>
        <item name="colorSurface">@color/fz_surface</item>
        <item name="colorOnSurface">@color/fz_text</item>
    </style>

    <style name="FzHomeCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">88dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_margin">5dp</item>
        <item name="android:background">@drawable/settings_row_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textColor">@color/fz_text</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingExtra">8dp</item>
    </style>

    <style name="FzBackButton">
        <item name="android:layout_width">42dp</item>
        <item name="android:layout_height">42dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/fz_text</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="FzFilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_marginRight">8dp</item>
        <item name="android:background">@drawable/settings_row_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingLeft">13dp</item>
        <item name="android:paddingRight">13dp</item>
        <item name="android:textColor">@color/fz_text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="FzSectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">22dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">@color/fz_text_muted</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="FzSettingsRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/settings_row_bg</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textColor">@color/fz_text</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="FzCallButton">
        <item name="android:layout_width">96dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="android:background">@drawable/settings_row_bg</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/fz_text</item>
        <item name="android:textSize">13sp</item>
    </style>
</resources>
